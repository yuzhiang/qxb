<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/et_setting_nick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_todo_item"
            android:hint="请输入昵称"
            android:padding="12dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="专注退出密码"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_setting_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_todo_item"
            android:hint="设置专注退出密码（可空）"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_setting_password_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_todo_item"
            android:hint="确认专注退出密码"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/cb_setting_show_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="显示密码" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="安全问题（用于忘记密码重置）"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_setting_pw_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_todo_item"
        android:hint="推荐：身份证后四位"
            android:padding="12dp"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_setting_pw_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_todo_item"
            android:hint="答案"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_setting_clear_pw"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="清除密码" />

            <Button
                android:id="@+id/btn_setting_reset_pw"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="忘记密码重置" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_setting_rules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="规则设置" />

        <Button
            android:id="@+id/btn_setting_rewards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="激励设置" />

    </LinearLayout>
</ScrollView>
