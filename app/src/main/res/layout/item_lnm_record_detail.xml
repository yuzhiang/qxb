<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_todo_item"
    android:padding="10dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_record_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2026-03-02 09:00 ~ 10:00"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="@android:color/black" />

    <TextView
        android:id="@+id/tv_record_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="时长 60m · 成功 · 亮屏 2 次"
        android:textSize="12sp"
        android:textColor="@color/colorTextAssistant" />
</LinearLayout>
