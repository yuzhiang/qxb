<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="2dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <View
        android:id="@+id/v_todo_level_line"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/colorDivision"
        app:layout_constraintTop_toTopOf="@id/tv_todo_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_todo_countdown"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="9dp" />

    <TextView
        android:id="@+id/tv_todo_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:text="作业标题"
        android:textColor="@color/colorTextContent"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/v_todo_level_line"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cb_todo_done" />

    <CheckBox
        android:id="@+id/cb_todo_done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/colorPrimary"
        android:contentDescription="完成"
        app:layout_constraintTop_toTopOf="@id/tv_todo_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_todo_countdown"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_todo_repeat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_tag"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="不重复"
        android:textColor="@color/colorTextAssistant"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/tv_todo_title"
        app:layout_constraintTop_toBottomOf="@id/tv_todo_title" />

    <TextView
        android:id="@+id/tv_todo_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="未打卡"
        android:textColor="@color/colorTextAssistant"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/tv_todo_repeat"
        app:layout_constraintBaseline_toBaselineOf="@id/tv_todo_repeat" />

    <TextView
        android:id="@+id/tv_todo_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="剩余 2天 5小时 10分钟"
        android:textColor="@color/colorPrimaryDark"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tv_todo_repeat"
        app:layout_constraintStart_toEndOf="@id/tv_todo_status" />

    <View
        android:id="@+id/v_todo_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="6dp"
        android:background="@color/colorDivision"
        app:layout_constraintStart_toStartOf="@id/tv_todo_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_todo_repeat"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
