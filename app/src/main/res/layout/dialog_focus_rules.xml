<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="启用规则"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/sw_rules_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="规则模板"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/sp_rule_template"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="上学日"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_school_homework"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="作业时间：18:00 - 20:00" />

        <TextView
            android:id="@+id/tv_school_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="睡眠时间：21:00 - 06:30" />

        <TextView
            android:id="@+id/tv_school_free"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="自由时间：16:00 - 18:00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="周末"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_weekend_homework"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="作业时间：09:00 - 11:00" />

        <TextView
            android:id="@+id/tv_weekend_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="睡眠时间：21:00 - 07:00" />

        <TextView
            android:id="@+id/tv_weekend_free"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:padding="10dp"
            android:text="自由时间：14:00 - 18:00" />

    </LinearLayout>
</ScrollView>
