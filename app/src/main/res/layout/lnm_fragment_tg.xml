<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_white">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/abl_ltj"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/lnm_tj_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?android:attr/actionBarSize">

            <TextView
                android:layout_gravity="start|center_vertical"
                android:id="@+id/tv_lnm_tj_title"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="专注统计"
                android:textColor="@android:color/white"
                android:textSize="18sp" />


            <TextView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/tv_stat_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="12dp"
                android:text="显示学科统计"
                android:textSize="12sp" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>


    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/SwipeRefreshLayout_lnm_tg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:srlAccentColor="@android:color/white"
        app:srlEnablePreviewInEditMode="true"
        app:srlPrimaryColor="?attr/colorPrimaryDark">

        <com.scwang.smart.refresh.header.ClassicsHeader
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/include_important_banner"
                layout="@layout/view_important_banner" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/layout_stats_cards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_summary"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="关键指标"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_seed_data"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="生成测试数据"
                                android:textSize="12sp"
                                android:textColor="@color/colorPrimary" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stat_today_time"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="规则遵守：--"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/tv_stat_today_count"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="作业专注：--"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="12dp"
                                android:background="#EEEEEE" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="习惯概览"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_stat_week"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="早睡达标：0/7 天"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_stat_month"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="连续打卡：专注 0 天 · 早睡 0 天"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_stat_year"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="本年：0h 0m · 平均 0m · 差 0m"
                                    android:visibility="gone"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_weeks"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tv_lnm_count3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="?attr/colorPrimaryDark"
                                android:elevation="5dp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:text="作业专注趋势（近7天）"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />

                            <com.github.mikephil.charting.charts.LineChart
                                android:id="@+id/chart_lnm_weeks"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:layout_below="@+id/tv_lnm_count3"
                                android:layout_margin="8dp" />

                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_sleep_report"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_sleep_report_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="睡眠报告"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_sleep_report_hint"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="暂无睡眠报告"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btn_sleep_report_history"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="查看历史睡眠报告" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_project"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_project_title"
                                app:layout_constraintTop_toTopOf="parent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="学科分布（分钟）"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@+id/tv_project_title"
                                android:id="@+id/layout_project_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_project_unit_min"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_tag"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:text="分钟"
                                    android:textColor="@color/colorPrimary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_project_unit_sec"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_tag"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:text="秒"
                                    android:textColor="@android:color/darker_gray"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <com.github.mikephil.charting.charts.PieChart
                                app:layout_constraintTop_toBottomOf="@+id/tv_project_title"
                                android:id="@+id/chart_project_pie"
                                android:layout_width="match_parent"
                                android:layout_height="260dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                app:layout_constraintTop_toBottomOf="@+id/chart_project_pie"
                                android:id="@+id/tv_project_bar_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="学科时长（分钟）"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.github.mikephil.charting.charts.BarChart
                                app:layout_constraintTop_toBottomOf="@+id/tv_project_bar_title"
                                android:id="@+id/chart_project_bar"
                                android:layout_width="match_parent"
                                android:layout_height="220dp" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_record"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_record_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="睡眠尝试玩手机（近7天）"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.github.mikephil.charting.charts.LineChart
                                android:id="@+id/chart_record_trend"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:layout_marginTop="8dp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_stat_reward"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/card_red_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tv_reward_trend_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="奖励/兑换趋势（近7天）"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.github.mikephil.charting.charts.LineChart
                                android:id="@+id/chart_reward_trend"
                                android:layout_width="match_parent"
                                android:layout_height="220dp"
                                android:layout_marginTop="8dp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.scwang.smart.refresh.layout.SmartRefreshLayout>


</LinearLayout>
